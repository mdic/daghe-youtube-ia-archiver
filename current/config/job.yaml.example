job_name: "daghe-youtube-ia-archiver"

# The unlisted or public playlist to monitor
playlist_url: "https://www.youtube.com/playlist?list=YOUR_PLAYLIST_ID"

ia_settings:
  collection: "opensource_movies"
  # S3 Keys must be in this file as IA_ACCESS_KEY and IA_SECRET_KEY
  credentials_file: "${BASE_DIR}/config/ia.env"
  # Prefix template for the Internet Archive description
  description_template: "config/description_prefix.txt"

paths:
  data_dir: "${BASE_DIR}/jobs/daghe-youtube-ia-archiver/data"
  archive_file: "${BASE_DIR}/jobs/daghe-youtube-ia-archiver/data/archived_videos.txt"
  temp_work_dir: "${BASE_DIR}/jobs/daghe-youtube-ia-archiver/data/tmp"
  telegram_helper: "${BASE_DIR}/bin/telegram-notify.sh"

yt_dlp:
  # Reusing the shared cookie strategy
  cookie_file: "${BASE_DIR}/config/cookies/daghe-youtube-search-metadata.txt"
  extra_ydl_opts:
    # Prefer non-AI-upscaled videos, as of today identified with format_id containing "-sr"
    format: "bestvideo[format_id!*=sr]+bestaudio/best[format_id!*=sr]"
    subtitleslangs:
        - "en.*"
        - "it.*"
    writesubtitles: true
    write_auto_subs: false
    ignore_no_formats_error: false
    sleep_interval_requests: 2
    check_formats: true

git:
  enabled: true
  branch: "main"
  auto_push: true
  commit_message_template: "ia-archiver: {new_count} videos archived"

telegram:
  enabled: true
  notify_on_success: true
