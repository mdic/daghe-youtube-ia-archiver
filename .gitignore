# Standard Python
__pycache__/
.venv/
.env
*.pyc

# Data Confinement
# Ignore everything in data/ except the .gitkeep file
data/*
../data/
../data/*
!data/.gitkeep

# Config Safety
# If you use 'config/' (standard)
current/config/*.yaml
!current/config/*.yaml.example
!current/config/.gitkeep
daghe-module.yaml
description_prefix.txt
